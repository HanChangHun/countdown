{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Countdown",
  "version": "0.1.4",
  "identifier": "io.github.hanchanghun.countdown",
  "build": {
    "frontendDist": "../src",
    "devUrl": null,
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Countdown",
        "width": 760,
        "height": 640,
        "minWidth": 360,
        "minHeight": 240,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self'; object-src 'none'; base-uri 'none'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/HanChangHun/countdown-web/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk5MkE5ODJFNTMwNTYzNkEKUldScVl3VlRMcGdxbVVsbGZIYTRIanN2UDdDNW9XdStXK0hJNXVkUmdNWmtWdGtFQVU0KzJhMGUK",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
